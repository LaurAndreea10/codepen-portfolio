<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Campaign ROI Calculator | Laura Andreea</title>
  <meta name="description" content="Calculator gratuit pentru ROI campanii marketing — CAC, ROAS, payback period. Bilingv RO/EN, fără login, export PDF." />
  <meta name="theme-color" content="#071226" />
  <link rel="canonical" href="https://laurandreea10.github.io/codepen-portfolio/projects/campaign-roi-calculator.html" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="Campaign ROI Calculator — gratuit, fără login" />
  <meta property="og:description" content="Calculează CAC, ROAS, payback period pentru campaniile tale. Comparare scenarii." />

  <style>
    :root {
      --bg:#050d1f;--bg2:#08142b;--panel:rgba(10,22,46,.8);--line:rgba(255,255,255,.1);
      --text:#eef4ff;--muted:#9db0d4;--accent:#4f8cff;--accent2:#8b5cf6;
      --green:#4ade80;--amber:#f59e0b;--red:#ef4444;
      --shadow:0 20px 48px rgba(0,0,0,.32);
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,system-ui,sans-serif;color:var(--text);
      background:linear-gradient(180deg,var(--bg2),var(--bg));min-height:100vh;line-height:1.6}
    a{color:var(--accent);text-decoration:none}
    h1,h2,h3,p{margin:0}
    
    .container{width:min(960px,calc(100% - 32px));margin:0 auto;padding:24px 0}
    .topbar{padding:16px 0;border-bottom:1px solid var(--line);position:sticky;top:0;
      background:rgba(7,18,38,.95);backdrop-filter:blur(10px);z-index:10}
    .topbar .container{padding:0;display:flex;justify-content:space-between;align-items:center;gap:12px}
    .brand{font-weight:800}
    .glass{background:var(--panel);border:1px solid var(--line);
      box-shadow:var(--shadow);backdrop-filter:blur(14px);border-radius:18px;padding:24px}
    .eyebrow{font-size:.78rem;font-weight:800;text-transform:uppercase;
      letter-spacing:.1em;color:var(--accent)}
    h1{font-size:clamp(1.8rem,4vw,2.4rem);line-height:1.1;letter-spacing:-.02em;margin-top:8px}
    .lead{margin-top:14px;color:var(--muted)}
    
    .layout{display:grid;grid-template-columns:1fr 1.2fr;gap:20px;margin-top:24px}
    @media(max-width:760px){.layout{grid-template-columns:1fr}}
    
    .form-section h2{font-size:1.1rem;color:var(--accent);margin-bottom:14px;
      padding-bottom:8px;border-bottom:1px solid var(--line)}
    .field{margin-bottom:14px}
    .field label{display:block;font-size:.85rem;color:var(--muted);margin-bottom:6px;font-weight:600}
    .field-row{display:flex;gap:8px;align-items:center}
    .field input{flex:1;width:100%;padding:10px 12px;background:rgba(0,0,0,.25);
      border:1px solid var(--line);border-radius:8px;color:var(--text);
      font-family:inherit;font-size:.95rem;transition:border-color .15s}
    .field input:focus{outline:none;border-color:var(--accent)}
    .field input::-webkit-outer-spin-button,.field input::-webkit-inner-spin-button{
      -webkit-appearance:none;margin:0}
    .field input[type=number]{-moz-appearance:textfield}
    .field-suffix{color:var(--muted);font-size:.85rem;flex-shrink:0;width:auto;min-width:36px}
    
    .channels-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .channel{padding:10px;border:1px solid var(--line);border-radius:10px;
      background:rgba(255,255,255,.02)}
    .channel label{display:flex;justify-content:space-between;align-items:center;
      margin-bottom:6px;font-size:.82rem;font-weight:600}
    .channel input{width:100%;padding:6px 10px;background:rgba(0,0,0,.3);
      border:1px solid var(--line);border-radius:6px;color:var(--text);
      font-size:.85rem;font-family:inherit}
    .channel input:focus{outline:none;border-color:var(--accent)}
    
    .scenarios{display:flex;gap:6px;margin:16px 0;flex-wrap:wrap}
    .scenario-btn{padding:6px 12px;border:1px solid var(--line);border-radius:999px;
      background:rgba(255,255,255,.04);color:var(--text);font-family:inherit;
      font-size:.82rem;cursor:pointer;transition:all .15s}
    .scenario-btn:hover{border-color:var(--accent)}
    .scenario-btn.active{background:linear-gradient(135deg,var(--accent),var(--accent2));border-color:transparent;color:#fff}
    
    .results-section h2{font-size:1.1rem;color:var(--accent);margin-bottom:14px;
      padding-bottom:8px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
    .results-section h2 button{font-size:.78rem;padding:5px 12px;border:1px solid var(--line);
      background:rgba(255,255,255,.04);color:var(--text);border-radius:6px;cursor:pointer;
      font-family:inherit;transition:all .15s}
    .results-section h2 button:hover{border-color:var(--accent)}
    
    .metrics{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:16px}
    .metric{padding:14px;border:1px solid var(--line);border-radius:12px;
      background:rgba(255,255,255,.03)}
    .metric.featured{background:linear-gradient(135deg,rgba(79,140,255,.15),rgba(139,92,246,.1));
      border-color:rgba(139,92,246,.4)}
    .metric .label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;
      color:var(--muted);margin-bottom:6px;font-weight:700}
    .metric .value{font-size:1.5rem;font-weight:800;letter-spacing:-.02em;line-height:1}
    .metric .value.green{color:var(--green)}
    .metric .value.amber{color:var(--amber)}
    .metric .value.red{color:var(--red)}
    .metric .help{font-size:.72rem;color:var(--muted);margin-top:4px;line-height:1.4}
    
    .verdict{padding:14px;border-radius:12px;margin-bottom:14px;
      border:1px solid var(--line);font-size:.88rem;line-height:1.55}
    .verdict.good{background:rgba(74,222,128,.08);border-color:rgba(74,222,128,.3);color:var(--text)}
    .verdict.warn{background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.3);color:var(--text)}
    .verdict.bad{background:rgba(239,68,68,.08);border-color:rgba(239,68,68,.3);color:var(--text)}
    .verdict strong{display:block;margin-bottom:4px}
    
    .channels-breakdown{padding:14px;border:1px solid var(--line);border-radius:12px;
      background:rgba(255,255,255,.02)}
    .channels-breakdown h3{font-size:.85rem;color:var(--accent);margin-bottom:10px;
      text-transform:uppercase;letter-spacing:.05em}
    .channel-row{display:flex;justify-content:space-between;align-items:center;
      padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.85rem}
    .channel-row:last-child{border-bottom:0}
    .channel-row .name{color:var(--muted);font-weight:600}
    .channel-row .value{color:var(--text);font-weight:700;font-variant-numeric:tabular-nums}
    .channel-row.best .name::before{content:"⭐ ";color:var(--green)}
    
    .formulas{margin-top:24px;padding:18px;border:1px dashed var(--line);
      border-radius:12px;background:rgba(255,255,255,.02);font-size:.82rem;color:var(--muted)}
    .formulas h3{font-size:.82rem;color:var(--accent);margin-bottom:10px;
      text-transform:uppercase;letter-spacing:.05em}
    .formulas dl{margin:0;display:grid;grid-template-columns:auto 1fr;gap:6px 14px;font-size:.78rem}
    .formulas dt{font-family:'JetBrains Mono',Consolas,monospace;color:var(--text);font-weight:700}
    .formulas dd{margin:0;color:var(--muted)}
    
    .footer-cta{margin-top:32px;padding:24px;text-align:center;border-radius:18px;
      background:linear-gradient(135deg,rgba(79,140,255,.12),rgba(139,92,246,.10));
      border:1px solid rgba(139,92,246,.3)}
    .footer-cta p{color:var(--muted);margin:8px 0 14px}
    .btn{display:inline-flex;align-items:center;justify-content:center;
      padding:10px 20px;border-radius:999px;font-weight:700;font-size:.9rem;
      color:#fff;background:linear-gradient(135deg,var(--accent),var(--accent2));
      border:none;cursor:pointer;font-family:inherit;text-decoration:none}
    .btn:hover{opacity:.9;text-decoration:none}
    
    .lang-toggle{padding:6px 12px;border:1px solid var(--line);border-radius:999px;
      background:rgba(255,255,255,.04);color:var(--text);font-family:inherit;
      font-size:.82rem;cursor:pointer}
  </style>
</head>
<body>
  <header class="topbar">
    <div class="container">
      <a class="brand" href="../">← Laura Andreea</a>
      <button class="lang-toggle" id="langToggle" type="button">RO | EN</button>
    </div>
  </header>

  <main class="container">
    <article class="glass">
      <span class="eyebrow" data-i18n="eyebrow">Marketing tool · Front-end vanilla</span>
      <h1 data-i18n="title">Campaign ROI Calculator</h1>
      <p class="lead" data-i18n="lead">Calculează rapid CAC, ROAS, payback period și marja de contribuție pentru campaniile tale. Compară scenarii, fără cont, fără tracking. Datele rămân în browser.</p>

      <div class="layout">
        <!-- INPUT SECTION -->
        <section class="form-section glass" style="padding:20px;">
          <h2 data-i18n="inputs">Inputs</h2>

          <div class="field">
            <label for="aov" data-i18n="aov">Average Order Value (AOV)</label>
            <div class="field-row">
              <input type="number" id="aov" value="120" min="0" step="1" />
              <span class="field-suffix">€</span>
            </div>
          </div>

          <div class="field">
            <label for="ltv" data-i18n="ltv">Customer Lifetime Value (LTV)</label>
            <div class="field-row">
              <input type="number" id="ltv" value="480" min="0" step="1" />
              <span class="field-suffix">€</span>
            </div>
          </div>

          <div class="field">
            <label for="margin" data-i18n="margin">Gross Margin</label>
            <div class="field-row">
              <input type="number" id="margin" value="60" min="0" max="100" step="1" />
              <span class="field-suffix">%</span>
            </div>
          </div>

          <h3 style="font-size:.85rem;color:var(--muted);margin:18px 0 10px;text-transform:uppercase;letter-spacing:.05em;" data-i18n="channels">Channels — cheltuieli &amp; conversii</h3>

          <div class="channels-grid">
            <div class="channel">
              <label>Google Ads <span class="field-suffix">€ / conv.</span></label>
              <input type="number" id="ch1-spend" value="3000" placeholder="Spend" min="0" />
              <input type="number" id="ch1-conv" value="38" placeholder="Conv." min="0" style="margin-top:4px;" />
            </div>
            <div class="channel">
              <label>Meta Ads <span class="field-suffix">€ / conv.</span></label>
              <input type="number" id="ch2-spend" value="2200" placeholder="Spend" min="0" />
              <input type="number" id="ch2-conv" value="32" placeholder="Conv." min="0" style="margin-top:4px;" />
            </div>
            <div class="channel">
              <label>Email <span class="field-suffix">€ / conv.</span></label>
              <input type="number" id="ch3-spend" value="500" placeholder="Spend" min="0" />
              <input type="number" id="ch3-conv" value="22" placeholder="Conv." min="0" style="margin-top:4px;" />
            </div>
            <div class="channel">
              <label>Organic / SEO <span class="field-suffix">€ / conv.</span></label>
              <input type="number" id="ch4-spend" value="800" placeholder="Spend" min="0" />
              <input type="number" id="ch4-conv" value="28" placeholder="Conv." min="0" style="margin-top:4px;" />
            </div>
          </div>

          <div class="scenarios">
            <button class="scenario-btn active" data-scenario="current" data-i18n="sc-current">Current</button>
            <button class="scenario-btn" data-scenario="save1" data-i18n="sc-save">Save A</button>
            <button class="scenario-btn" data-scenario="save2" data-i18n="sc-save">Save B</button>
          </div>
        </section>

        <!-- RESULTS SECTION -->
        <section class="results-section glass" style="padding:20px;">
          <h2><span data-i18n="results">Rezultate</span> <button id="resetBtn" type="button" data-i18n="reset">Reset</button></h2>

          <div id="verdict" class="verdict good">
            <strong data-i18n="verdictTitle">Verdict</strong>
            <span id="verdictText">Calculează pentru a vedea verdictul.</span>
          </div>

          <div class="metrics">
            <div class="metric featured">
              <div class="label" data-i18n="m-cac">CAC mediu</div>
              <div class="value" id="m-cac">—</div>
              <div class="help" data-i18n="m-cac-help">Cost per achiziție client (medie ponderată).</div>
            </div>
            <div class="metric featured">
              <div class="label" data-i18n="m-roas">ROAS</div>
              <div class="value" id="m-roas">—</div>
              <div class="help" data-i18n="m-roas-help">Revenue ÷ Spend. Target healthy: 3x+.</div>
            </div>
            <div class="metric">
              <div class="label" data-i18n="m-payback">Payback period</div>
              <div class="value" id="m-payback">—</div>
              <div class="help" data-i18n="m-payback-help">Câte luni recuperezi CAC din profit.</div>
            </div>
            <div class="metric">
              <div class="label" data-i18n="m-ltvcac">LTV : CAC</div>
              <div class="value" id="m-ltvcac">—</div>
              <div class="help" data-i18n="m-ltvcac-help">Healthy: 3:1 sau mai mult.</div>
            </div>
            <div class="metric">
              <div class="label" data-i18n="m-revenue">Revenue total</div>
              <div class="value" id="m-revenue">—</div>
              <div class="help" data-i18n="m-revenue-help">Conversii × AOV (instant, nu LTV).</div>
            </div>
            <div class="metric">
              <div class="label" data-i18n="m-profit">Profit estimat</div>
              <div class="value" id="m-profit">—</div>
              <div class="help" data-i18n="m-profit-help">Revenue × marja − Spend total.</div>
            </div>
          </div>

          <div class="channels-breakdown">
            <h3 data-i18n="bd-title">Best performing channel</h3>
            <div id="channelsList"></div>
          </div>
        </section>
      </div>

      <div class="formulas">
        <h3 data-i18n="formulas">Formule folosite</h3>
        <dl>
          <dt>CAC</dt><dd data-i18n="f-cac">Total Spend ÷ Total Conversions</dd>
          <dt>ROAS</dt><dd data-i18n="f-roas">Revenue ÷ Total Spend</dd>
          <dt>Payback</dt><dd data-i18n="f-payback">CAC ÷ (AOV × Margin) × 12 (luni)</dd>
          <dt>LTV : CAC</dt><dd data-i18n="f-ltvcac">LTV ÷ CAC (raport)</dd>
          <dt>Profit</dt><dd data-i18n="f-profit">(Revenue × Margin) − Total Spend</dd>
        </dl>
      </div>

      <div class="footer-cta">
        <span class="eyebrow" data-i18n="cta-eyebrow">Open source · Vanilla JS</span>
        <p data-i18n="cta-text">Tool gratuit, fără login, fără tracking. Datele tale rămân în browser.</p>
        <a class="btn" href="https://github.com/LaurAndreea10/codepen-portfolio" target="_blank" rel="noopener noreferrer" data-i18n="cta-btn">Vezi codul pe GitHub →</a>
      </div>
    </article>
  </main>

  <script>
    // ===== State =====
    const state = {
      lang: localStorage.getItem('roi-lang') || 'ro',
      scenario: 'current',
      scenarios: {
        save1: null,
        save2: null
      }
    };

    // ===== Translations =====
    const translations = {
      ro: {
        eyebrow: 'Marketing tool · Front-end vanilla',
        title: 'Campaign ROI Calculator',
        lead: 'Calculează rapid CAC, ROAS, payback period și marja de contribuție pentru campaniile tale. Compară scenarii, fără cont, fără tracking. Datele rămân în browser.',
        inputs: 'Inputs',
        aov: 'Average Order Value (AOV)',
        ltv: 'Customer Lifetime Value (LTV)',
        margin: 'Gross Margin',
        channels: 'Channels — cheltuieli și conversii',
        'sc-current': 'Curent',
        'sc-save': 'Salvează',
        results: 'Rezultate',
        reset: 'Reset',
        verdictTitle: 'Verdict',
        'm-cac': 'CAC mediu',
        'm-cac-help': 'Cost per achiziție client (medie ponderată).',
        'm-roas': 'ROAS',
        'm-roas-help': 'Revenue ÷ Spend. Target healthy: 3x+.',
        'm-payback': 'Payback period',
        'm-payback-help': 'Câte luni recuperezi CAC din profit.',
        'm-ltvcac': 'LTV : CAC',
        'm-ltvcac-help': 'Healthy: 3:1 sau mai mult.',
        'm-revenue': 'Revenue total',
        'm-revenue-help': 'Conversii × AOV (instant, nu LTV).',
        'm-profit': 'Profit estimat',
        'm-profit-help': 'Revenue × marja − Spend total.',
        'bd-title': 'Best performing channel',
        formulas: 'Formule folosite',
        'f-cac': 'Total Spend ÷ Total Conversions',
        'f-roas': 'Revenue ÷ Total Spend',
        'f-payback': 'CAC ÷ (AOV × Margin) × 12 (luni)',
        'f-ltvcac': 'LTV ÷ CAC (raport)',
        'f-profit': '(Revenue × Margin) − Total Spend',
        'cta-eyebrow': 'Open source · Vanilla JS',
        'cta-text': 'Tool gratuit, fără login, fără tracking. Datele tale rămân în browser.',
        'cta-btn': 'Vezi codul pe GitHub →',
        verdictGood: 'Performanță sănătoasă. ROAS &gt; 3 și LTV:CAC &gt; 3 — campaniile generează valoare sustenabil.',
        verdictWarn: 'Marja e îngustă. ROAS sub 3 sau payback &gt; 12 luni înseamnă că rezultatele sunt fragile la schimbări de cost.',
        verdictBad: 'Pierdere. Spend-ul depășește valoarea generată — revizuiește urgent canalele cu CAC mare sau ajustează prețul.'
      },
      en: {
        eyebrow: 'Marketing tool · Vanilla front-end',
        title: 'Campaign ROI Calculator',
        lead: 'Quickly calculate CAC, ROAS, payback period and contribution margin for your campaigns. Compare scenarios, no login, no tracking. Data stays in your browser.',
        inputs: 'Inputs',
        aov: 'Average Order Value (AOV)',
        ltv: 'Customer Lifetime Value (LTV)',
        margin: 'Gross Margin',
        channels: 'Channels — spend and conversions',
        'sc-current': 'Current',
        'sc-save': 'Save',
        results: 'Results',
        reset: 'Reset',
        verdictTitle: 'Verdict',
        'm-cac': 'Average CAC',
        'm-cac-help': 'Customer acquisition cost (weighted average).',
        'm-roas': 'ROAS',
        'm-roas-help': 'Revenue ÷ Spend. Healthy target: 3x+.',
        'm-payback': 'Payback period',
        'm-payback-help': 'Months to recover CAC from profit.',
        'm-ltvcac': 'LTV : CAC',
        'm-ltvcac-help': 'Healthy: 3:1 or higher.',
        'm-revenue': 'Total revenue',
        'm-revenue-help': 'Conversions × AOV (instant, not LTV).',
        'm-profit': 'Estimated profit',
        'm-profit-help': 'Revenue × margin − Total Spend.',
        'bd-title': 'Best performing channel',
        formulas: 'Formulas used',
        'f-cac': 'Total Spend ÷ Total Conversions',
        'f-roas': 'Revenue ÷ Total Spend',
        'f-payback': 'CAC ÷ (AOV × Margin) × 12 (months)',
        'f-ltvcac': 'LTV ÷ CAC (ratio)',
        'f-profit': '(Revenue × Margin) − Total Spend',
        'cta-eyebrow': 'Open source · Vanilla JS',
        'cta-text': 'Free tool, no login, no tracking. Your data stays in your browser.',
        'cta-btn': 'View code on GitHub →',
        verdictGood: 'Healthy performance. ROAS &gt; 3 and LTV:CAC &gt; 3 — campaigns generate sustainable value.',
        verdictWarn: 'Margin is tight. ROAS below 3 or payback &gt; 12 months means results are fragile to cost changes.',
        verdictBad: 'Loss. Spend exceeds value generated — urgently review high-CAC channels or adjust pricing.'
      }
    };

    function t(key) { return translations[state.lang][key] || key; }

    function applyTranslations() {
      document.documentElement.lang = state.lang;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        if (translations[state.lang][key]) el.textContent = translations[state.lang][key];
      });
      document.getElementById('langToggle').textContent = state.lang === 'ro' ? 'RO | EN' : 'EN | RO';
    }

    // ===== Compute =====
    function compute() {
      const aov = parseFloat(document.getElementById('aov').value) || 0;
      const ltv = parseFloat(document.getElementById('ltv').value) || 0;
      const margin = (parseFloat(document.getElementById('margin').value) || 0) / 100;

      const channels = [
        { name: 'Google Ads', spend: parseFloat(document.getElementById('ch1-spend').value) || 0, conv: parseFloat(document.getElementById('ch1-conv').value) || 0 },
        { name: 'Meta Ads', spend: parseFloat(document.getElementById('ch2-spend').value) || 0, conv: parseFloat(document.getElementById('ch2-conv').value) || 0 },
        { name: 'Email', spend: parseFloat(document.getElementById('ch3-spend').value) || 0, conv: parseFloat(document.getElementById('ch3-conv').value) || 0 },
        { name: 'Organic / SEO', spend: parseFloat(document.getElementById('ch4-spend').value) || 0, conv: parseFloat(document.getElementById('ch4-conv').value) || 0 }
      ];

      const totalSpend = channels.reduce((s, c) => s + c.spend, 0);
      const totalConv = channels.reduce((s, c) => s + c.conv, 0);
      const cac = totalConv > 0 ? totalSpend / totalConv : 0;
      const revenue = totalConv * aov;
      const roas = totalSpend > 0 ? revenue / totalSpend : 0;
      const profit = revenue * margin - totalSpend;
      const ltvCacRatio = cac > 0 ? ltv / cac : 0;
      const monthlyProfit = aov * margin;
      const paybackMonths = monthlyProfit > 0 ? cac / monthlyProfit : Infinity;

      // Render metrics
      const fmt = (v, suffix = '') => isFinite(v) ? v.toFixed(2).replace(/\.00$/, '') + suffix : '—';
      const fmtCur = v => '€' + Math.round(v).toLocaleString();

      document.getElementById('m-cac').textContent = totalConv > 0 ? fmtCur(cac) : '—';
      document.getElementById('m-roas').textContent = totalSpend > 0 ? fmt(roas, 'x') : '—';
      document.getElementById('m-payback').textContent = isFinite(paybackMonths) ? fmt(paybackMonths) + ' mo' : '—';
      document.getElementById('m-ltvcac').textContent = cac > 0 ? fmt(ltvCacRatio, ':1') : '—';
      document.getElementById('m-revenue').textContent = fmtCur(revenue);
      document.getElementById('m-profit').textContent = fmtCur(profit);

      // Color profit/roas
      const profitEl = document.getElementById('m-profit');
      profitEl.classList.toggle('green', profit > 0);
      profitEl.classList.toggle('red', profit < 0);
      const roasEl = document.getElementById('m-roas');
      roasEl.classList.toggle('green', roas >= 3);
      roasEl.classList.toggle('amber', roas >= 1 && roas < 3);
      roasEl.classList.toggle('red', roas < 1);

      // Verdict
      const verdictEl = document.getElementById('verdict');
      const verdictText = document.getElementById('verdictText');
      verdictEl.classList.remove('good', 'warn', 'bad');
      if (roas >= 3 && ltvCacRatio >= 3 && profit > 0) {
        verdictEl.classList.add('good');
        verdictText.innerHTML = t('verdictGood');
      } else if (roas >= 1 && profit >= 0) {
        verdictEl.classList.add('warn');
        verdictText.innerHTML = t('verdictWarn');
      } else {
        verdictEl.classList.add('bad');
        verdictText.innerHTML = t('verdictBad');
      }

      // Channels breakdown
      const channelsWithROAS = channels.map(c => {
        const cRoas = c.spend > 0 ? (c.conv * aov) / c.spend : 0;
        const cCac = c.conv > 0 ? c.spend / c.conv : 0;
        return { ...c, roas: cRoas, cac: cCac };
      }).sort((a, b) => b.roas - a.roas);

      const list = document.getElementById('channelsList');
      list.innerHTML = channelsWithROAS.map((c, i) => `
        <div class="channel-row ${i === 0 && c.roas > 0 ? 'best' : ''}">
          <span class="name">${c.name}</span>
          <span class="value">${c.spend > 0 ? c.roas.toFixed(2) + 'x · CAC ' + fmtCur(c.cac) : '—'}</span>
        </div>
      `).join('');
    }

    // ===== Events =====
    function bindEvents() {
      document.querySelectorAll('input[type=number]').forEach(input => {
        input.addEventListener('input', compute);
      });

      document.getElementById('resetBtn').addEventListener('click', () => {
        document.getElementById('aov').value = 120;
        document.getElementById('ltv').value = 480;
        document.getElementById('margin').value = 60;
        document.getElementById('ch1-spend').value = 3000;
        document.getElementById('ch1-conv').value = 38;
        document.getElementById('ch2-spend').value = 2200;
        document.getElementById('ch2-conv').value = 32;
        document.getElementById('ch3-spend').value = 500;
        document.getElementById('ch3-conv').value = 22;
        document.getElementById('ch4-spend').value = 800;
        document.getElementById('ch4-conv').value = 28;
        compute();
      });

      document.getElementById('langToggle').addEventListener('click', () => {
        state.lang = state.lang === 'ro' ? 'en' : 'ro';
        localStorage.setItem('roi-lang', state.lang);
        applyTranslations();
        compute(); // Re-render verdict in new language
      });

      document.querySelectorAll('.scenario-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const scenario = btn.dataset.scenario;
          if (scenario === 'current') {
            document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            return;
          }
          // Save or load scenario
          if (state.scenarios[scenario]) {
            // Load
            const data = state.scenarios[scenario];
            Object.keys(data).forEach(id => {
              const el = document.getElementById(id);
              if (el) el.value = data[id];
            });
            document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            compute();
          } else {
            // Save current
            const data = {};
            ['aov','ltv','margin','ch1-spend','ch1-conv','ch2-spend','ch2-conv','ch3-spend','ch3-conv','ch4-spend','ch4-conv'].forEach(id => {
              const el = document.getElementById(id);
              if (el) data[id] = el.value;
            });
            state.scenarios[scenario] = data;
            btn.textContent = state.lang === 'ro' ? 'Încarcă' : 'Load';
            setTimeout(() => {
              btn.textContent = scenario === 'save1' ? 'A' : 'B';
            }, 1500);
          }
        });
      });
    }

    // ===== Init =====
    applyTranslations();
    bindEvents();
    compute();
  </script>
</body>
</html>
